generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id              Int                  @id @default(autoincrement())
  name            String
  repoOwner       String
  repoName        String
  totalAmount     Float                @default(0)
  sponsorAddress  String               @default("")
  isActive        Boolean              @default(false)
  createdAt       DateTime             @default(now())
  eligibilities   Eligibility[]
  commitments     IdentityCommitment[]
  rounds          Round[]
}

model Eligibility {
  id          Int      @id @default(autoincrement())
  githubLogin String
  isEligible  Boolean
  checkedAt   DateTime @default(now())

  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@index([githubLogin])
  @@index([campaignId])
}

model IdentityCommitment {
  id          Int      @id @default(autoincrement())
  githubLogin String
  commitment  String   @unique
  createdAt   DateTime @default(now())

  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@index([githubLogin])
  @@index([campaignId])
}

model Round {
  id              Int      @id @default(autoincrement())
  name            String
  isActive        Boolean  @default(false)
  amountPerClaim  Float
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime @default(now())

  campaignId      Int
  campaign        Campaign @relation(fields: [campaignId], references: [id])

  nullifiers      Nullifier[]
  distributions   Distribution[]

  @@index([campaignId])
}

model Nullifier {
  id             Int      @id @default(autoincrement())
  nullifierHash  String   @unique
  createdAt      DateTime @default(now())

  roundId        Int
  round          Round    @relation(fields: [roundId], references: [id])

  @@index([roundId])
}

model Distribution {
  id             Int      @id @default(autoincrement())
  walletAddress  String
  amount         Float
  nullifierHash  String
  createdAt      DateTime @default(now())

  roundId        Int
  round          Round    @relation(fields: [roundId], references: [id])

  @@index([roundId])
  @@index([walletAddress])
}
